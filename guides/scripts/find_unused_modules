  'guides/common/modules/proc_providing-an-alternative-fqdn-for-the-host.adoc',
  'guides/common/modules/proc_providing-the-hosts-ip-address.adoc',
  'guides/common/modules/proc_refreshing-clients-of-insights-iop.adoc',
  'guides/common/modules/proc_registering-a-host-for-content-management-only.adoc',
  'guides/common/modules/proc_registering-a-host-without-puppet.adoc',
  'guides/common/modules/proc_registering-clients-using-the-bootstrap-script.adoc',
  'guides/common/modules/proc_registering-hosts-by-using-the-bootstrap-script.adoc',
  'guides/common/modules/proc_resolving-package-dependency-errors.adoc',
  'guides/common/modules/proc_reverting-server-to-download-content-from-red-hat-cdn-by-using-cli.adoc',
  'guides/common/modules/proc_reverting-server-to-download-content-from-red-hat-cdn-by-using-web-ui.adoc',
  'guides/common/modules/proc_reviewing-usage-metrics-collected-from-your-project.adoc',
  'guides/common/modules/proc_setting-permissions-for-the-bootstrap-script-by-using-cli.adoc',
  'guides/common/modules/proc_setting-permissions-for-the-bootstrap-script-by-using-web-ui.adoc',
  'guides/common/modules/proc_synchronizing-the-new-repositories.adoc',
  'guides/common/modules/proc_updating-server.adoc',
  'guides/common/modules/proc_updating-smart-proxy.adoc',
  'guides/common/modules/proc_upgrading-a-disconnected-project-server.adoc',
  'guides/common/modules/proc_upgrading-container-images-of-insights-iop.adoc',
  'guides/common/modules/proc_upgrading-puppet-agent-7-to-openvox-agent-8.adoc',
  'guides/common/modules/ref_advanced-bootstrap-script-configuration.adoc',
  'guides/common/modules/ref_host-requirements-for-custom-images.adoc',
  'guides/common/modules/ref_managing-packages-on-the-base-operating-system.adoc',
  'guides/common/modules/ref_preconfigured-rhel-kvm-guest-images.adoc',
  'guides/common/modules/ref_supported-usage-of-project-components.adoc',
  'guides/common/modules/ref_troubleshooting-insights-iop.adoc',
  'guides/common/modules/ref_usage-metrics-collected-by-project.adoc',
  'guides/common/modules/snip_openvox-client-repos.adoc',
  'guides/common/assembly_building-cloud-images-for-project.adoc',
  'guides/common/assembly_cloning-project-server.adoc',
  'guides/common/assembly_configuring-inter-server-synchronization.adoc',
  'guides/common/assembly_installing-satellite-server-disconnected.adoc',
  'guides/common/assembly_monitoring-hosts-by-using-insights-in-project.adoc',
  'guides/common/assembly_updating-satellite.adoc',
  'guides/common/assembly_upgrading-project-disconnected.adoc',
  'guides/common/assembly_usage-metrics-collection-in-project.adoc'
]

non_containerized_satellite_content.each { |file| unused.delete(file) }

if unused.any?
  puts unused
  if ENV.key?('GITHUB_ACTIONS')
    unused.each do |file|
      puts "::error file=#{file}::File is unused"
    end
  end
  exit(1)
end
